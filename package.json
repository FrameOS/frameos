{
  "name": "@frameos/workspace",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "mprocs",
    "dev:backend": "cd backend && DEBUG=1 python -m alembic upgrade head && exec uvicorn app.fastapi:app --host 0.0.0.0 --port 8989 --reload",
    "dev:worker": "cd backend && DEBUG=1 arq app.tasks.worker.WorkerSettings",
    "dev:frontend": "pnpm --dir frontend run dev",
    "dev:frame-frontend": "pnpm --dir frameos/frontend run dev",
    "dev:redis": "redis-server"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18.0.19",
      "@types/react-dom": "18.0.6",
      "csstype": "3.2.3"
    }
  },
  "devDependencies": {
    "mprocs": "^0.8.3"
  }
}
