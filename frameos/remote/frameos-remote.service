# /etc/systemd/system/frameos-remote.service
[Unit]
Description=FrameOS Remote (auto-reconnect, hardened)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=%I
WorkingDirectory=/srv/frameos/remote/current
ExecStart=/srv/frameos/remote/current/frameos_remote
Restart=always
RestartSec=5
LimitNOFILE=65536
PrivateTmp=yes
ProtectSystem=full
ReadWritePaths=/etc/systemd/system /etc/cron.d /boot

[Install]
WantedBy=multi-user.target
