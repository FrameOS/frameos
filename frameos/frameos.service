[Unit]
Description=FrameOS Service
After=network.target

[Service]
User=%I
WorkingDirectory=/srv/frameos/current
ExecStart=/srv/frameos/current/frameos
Restart=always
Type=notify
TimeoutStartSec=300
# Restart if the runner loop stops sending WATCHDOG=1 heartbeats. 15 minutes
# tolerates the slowest legitimate renders (chromium retries, e-ink refresh).
WatchdogSec=900
# If FrameOS leaks memory, OOM-kill and restart it instead of letting the
# device swap itself into an unreachable state. This static unit (buildroot)
# uses percentages; rpios installs compute absolute values from MemTotal in
# setup.nim (frameosServiceContents).
MemoryHigh=80%
MemoryMax=90%
MemorySwapMax=64M

[Install]
WantedBy=multi-user.target
