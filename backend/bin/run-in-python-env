#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

if [ "$#" -eq 0 ]; then
  echo "usage: $0 <tool> [args...]" >&2
  exit 1
fi

tool="$1"
shift

if [ -n "${VIRTUAL_ENV:-}" ] && [ -x "$VIRTUAL_ENV/bin/$tool" ]; then
  exec "$VIRTUAL_ENV/bin/$tool" "$@"
fi

if [ -x "$REPO_ROOT/backend/env/bin/$tool" ]; then
  exec "$REPO_ROOT/backend/env/bin/$tool" "$@"
fi

if [ -x "$REPO_ROOT/.venv/bin/$tool" ]; then
  exec "$REPO_ROOT/.venv/bin/$tool" "$@"
fi

exec "$tool" "$@"
