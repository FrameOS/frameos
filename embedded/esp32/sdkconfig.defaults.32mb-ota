# 32MB production profile with larger state storage.
CONFIG_ESPTOOLPY_FLASHSIZE_32MB=y
# CONFIG_ESPTOOLPY_FLASHSIZE_8MB is not set
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_ota_32mb.csv"
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y
# Keep the 24MB SPIFFS state partition below SPIFFS' 16-bit page index limit.
CONFIG_SPIFFS_PAGE_SIZE=512
