        },
        "data": {
          "code": "state{\"wikimediaMetadata\"}{\"description\"}.getStr(state{\"wikimediaMetadata\"}{\"title\"}.getStr(\"\"))",
          "codeArgs": [],
          "codeOutputs": [
            {
              "name": "text",
              "type": "text"
            }
          ],
          "codeJS": "(() => { const meta = state.wikimediaMetadata || {}; const lines = []; const title = meta.description || meta.title || ''; if (title) lines.push(title); if (meta.author) lines.push('By ' + meta.author); const details = []; if (meta.license) details.push(meta.license); if (meta.mode) details.push(meta.mode); if (details.length) lines.push(details.join(' - ')); return lines.join('\\n'); })()"
        },
        "type": "code",
