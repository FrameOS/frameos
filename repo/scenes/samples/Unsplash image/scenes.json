        "data": {
          "code": "state{\"unsplashMetadata\"}{\"description\"}.getStr(state{\"unsplashMetadata\"}{\"altDescription\"}.getStr(\"\"))",
          "codeArgs": [],
          "codeOutputs": [
            {
              "name": "text",
              "type": "text"
            }
          ],
          "codeJS": "(() => { const meta = state.unsplashMetadata || {}; const lines = []; const title = meta.description || meta.altDescription || meta.title || ''; if (title) lines.push(title); if (meta.author) lines.push('Photo by ' + meta.author + (meta.authorUsername ? ' (@' + meta.authorUsername + ')' : '')); const details = []; if (meta.location) details.push(meta.location); if (meta.search) details.push('Search: ' + meta.search); if (details.length) lines.push(details.join(' - ')); return lines.join('\\n'); })()"
        },
