strict_env

if ! has flox; then
  log_error "flox is required to load this environment"
  exit 1
fi

repo_root="$(dirname "$(find_up .flox)")"

watch_file \
  "$repo_root/.flox/env/manifest.toml" \
  "$repo_root/.flox/env/manifest.lock" \
  "$repo_root/backend/requirements.txt" \
  "$repo_root/package.json" \
  "$repo_root/pnpm-lock.yaml" \
  "$repo_root/pnpm-workspace.yaml" \
  "$repo_root/frontend/package.json" \
  "$repo_root/frameos/frontend/package.json" \
  "$repo_root/frameos/frameos.nimble" \
  "$repo_root/frameos/nimble.lock" \
  "$repo_root/frameos/agent/frameos_agent.nimble" \
  "$repo_root/frameos/agent/nimble.lock"

eval "$(flox activate -d "$repo_root")"
